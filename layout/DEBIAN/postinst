#!/bin/bash

if [ -d "/var/jb" ]; then
    PREFIX="/var/jb"
else
    PREFIX=""
fi

mkdir -p "$PREFIX/var/mobile/Library/Preferences"
chown -R mobile:mobile "$PREFIX/var/mobile/Library/Preferences/com.chameleon.identities.plist" 2>/dev/null || true

if [ -f "$PREFIX/Library/MobileSubstrate/DynamicLibraries/Chameleon.plist" ]; then
    echo "Chameleon: Tweak registered with Substrate"
fi

if [ -f "$PREFIX/usr/bin/sbreload" ]; then
    "$PREFIX/usr/bin/sbreload"
elif [ -f "$PREFIX/usr/bin/killall" ]; then
    "$PREFIX/usr/bin/killall" -9 SpringBoard
fi

exit 0
